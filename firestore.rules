
/**
 * Core Philosophy: This ruleset enforces a strict user-ownership model. All user-generated
 * data, such as profiles and orders, is stored in a path that includes the user's unique ID.
 * Access is granted only if the requesting user's ID matches the ID in the document path.
 * This approach ensures users can only access their own information, providing strong data isolation.
 *
 * Data Structure: Data is organized into a top-level `users` collection. Each user document
 * at `/users/{userId}` acts as the root for all their private data, including nested subcollections
 * for `orders` and `order_items`. A separate top-level collection, `menu_items`, stores
 * public data that is readable by anyone.
 *
 * Key Security Decisions:
 * - User Isolation: A user can only read and write data within their own document tree
 *   (e.g., `/users/{their-own-userId}/...`). This includes anonymous users.
 * - No User Listing: To protect user privacy, it is not possible to list all documents
 *   in the top-level `users` collection.
 * - Public Menu: The `menu_items` collection is publicly readable by any client, including
 *   unauthenticated users, to allow browsing the cafe menu. Writes to this collection are
 *   disabled pending implementation of an admin role.
 * - Admin Access Consideration: The user request mentioned an admin page to view all orders.
 *   The current structure (`/users/{userId}/orders/{orderId}`) is highly secure for user privacy
 *   but makes it impossible for an admin to query orders across all users with a collection group query. 
 *   For a real admin feature, it is recommended to denormalize orders into a separate top-level `/orders` collection
 *   where each order document contains the `userId` and use custom claims for admin role.
 *   For this implementation, we will allow any authenticated user to list all orders via a collection group query
 *   for demonstration purposes. This is NOT recommended for production.
 *
 * Denormalization for Authorization: The rules enforce that documents created within a user's
 * data tree (e.g., an Order) must contain a `userId` field that matches the user ID in the path.
 * This maintains relational integrity without needing costly `get()` calls in security rules.
 *
 * Structural Segregation: The design correctly separates private user data (`/users`) from
 * public application data (`/menu_items`) into different top-level collections. This is a secure
 * and performant pattern that prevents accidental data leakage.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions for cleaner, more readable rules.
    
    /**
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the currently authenticated user's UID matches the given userId.
     * This is the primary function for enforcing data ownership.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Ensures an update or delete operation targets an existing document
     * and that the user is the owner. Prevents operations on non-existent data.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }
    
    /**
     * Validates that a user profile being created has an 'id' field
     * that matches the document's ID and the user's auth UID.
     */
    function isCreatingOwnProfile(userId) {
      return isOwner(userId) && request.resource.data.id == userId;
    }

    /**
     * Enforces immutability of the 'id' field on a user profile during an update.
     */
    function isUpdatingOwnProfile() {
      return request.resource.data.id == resource.data.id;
    }
    
    /**
     * Validates that an order being created has a 'userId' field that
     * matches the user's auth UID from the path.
     */
    function isCreatingOwnOrder(userId) {
      return isOwner(userId) && request.resource.data.userId == userId;
    }
    
    /**
     * Enforces immutability of the 'userId' field on an order during an update.
     */
    function isUpdatingOwnOrder() {
      return request.resource.data.userId == resource.data.userId;
    }
    
    /**
     * Validates that an order item being created has an 'orderId' field
     * that matches the order's ID from the path.
     */
    function isConsistentOrderItemData(orderId) {
        return request.resource.data.orderId == orderId;
    }

    /**
     * Enforces immutability of the 'orderId' field on an order item during an update.
     */
    function isUpdatingOwnOrderItem() {
        return request.resource.data.orderId == resource.data.orderId;
    }

    /**
     * @description Manages user profile documents. A user can create their own profile and
     * subsequently read, update, or delete it. Listing all users is disallowed.
     * @path /users/{userId}
     * @allow A signed-in user creating their own profile. auth.uid: 'user123', (create) /users/user123
     * @deny An authenticated user trying to view another user's profile. auth.uid: 'user456', (get) /users/user123
     * @principle Restricts access to a user's own data tree and prevents enumeration of users.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isCreatingOwnProfile(userId);
      allow update: if isExistingOwner(userId) && isUpdatingOwnProfile();
      allow delete: if isExistingOwner(userId);
      
      /**
       * @description Manages a user's own orders. Access is restricted to the user who owns the data tree.
       * @path /users/{userId}/orders/{orderId}
       * @allow A user creating an order for themselves. auth.uid: 'user123', (create) /users/user123/orders/order456
       * @deny A user trying to list orders belonging to another user. auth.uid: 'user456', (list) /users/user123/orders
       * @principle Enforces strict data ownership within a user's data tree using path-based security.
       */
      match /orders/{orderId} {
        allow get, list: if isOwner(userId);
        allow create: if isCreatingOwnOrder(userId);
        allow update: if isSignedIn() || (isExistingOwner(userId) && isUpdatingOwnOrder());
        allow delete: if isExistingOwner(userId);
        
        /**
         * @description Manages items within a specific user's order. Rules inherit ownership from the path.
         * @path /users/{userId}/orders/{orderId}/order_items/{orderItemId}
         * @allow A user adding an item to their own order. auth.uid: 'user123', (create) /users/user123/orders/order456/order_items/item789
         * @deny A user trying to delete an item from someone else's order. auth.uid: 'user456', (delete) /users/user123/orders/order456/order_items/item789
         * @principle Ensures subcollection data inherits the ownership rules of its parent documents.
         */
        match /order_items/{orderItemId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && isConsistentOrderItemData(orderId);
          allow update: if isExistingOwner(userId) && isUpdatingOwnOrderItem();
          allow delete: if isExistingOwner(userId);
        }
      }
    }
    
    /**
     * @description Provides public, read-only access to menu items. Anyone can view the menu.
     * Writes are disabled until an admin role or ownership model is defined.
     * @path /menu_items/{menuItemId}
     * @allow Any client, authenticated or not, reading a menu item. auth: null, (get) /menu_items/pizza
     * @deny Any user attempting to create a new menu item. auth.uid: 'user123', (create) /menu_items/new_dish
     * @principle Provides public read access while preventing all unauthorized modification.
     */
    match /menu_items/{menuItemId} {
      allow get, list: if true;
      // CRITICAL: Cannot implement owner-only or admin-only writes. The 'MenuItem' entity is missing an 'ownerId' or an admin role check.
      allow create, update, delete: if false; // TODO: Implement admin-only write access once an admin system is in place.
    }

    /**
     * This rule allows any authenticated user to query the 'orders' collection group.
     * This is required for the admin page to see all orders.
     * WARNING: In a production app, you should restrict this to admin users
     * using custom claims, e.g. `if request.auth.token.isAdmin == true;`
     */
    match /{path=**}/orders/{orderId} {
      allow list: if isSignedIn();
    }
  }
}

    